# Postgres
POSTGRES_USER=wealthfolio
POSTGRES_PASSWORD=change-me
POSTGRES_DB=wealthfolio

# Backend
CORS_ORIGIN=http://localhost:5173

# Google OAuth — create a Web application OAuth client in Google Cloud
# Console (console.cloud.google.com/apis/credentials) with an authorized
# redirect URI matching GOOGLE_REDIRECT_URL below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://money.example.com/api/v1/auth/google/callback

# Where the OAuth callback sends the browser after login (your frontend's
# real origin). Also used to default the session cookie's Secure flag
# (true when this is https).
APP_BASE_URL=https://money.example.com

# Frontend / Caddy — set to your real domain in production, e.g. money.example.com
# Leave as :80 to serve plain HTTP on a bare VPS IP (no automatic HTTPS).
DOMAIN=:80
